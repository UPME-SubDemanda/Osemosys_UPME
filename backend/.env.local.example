ENVIRONMENT=local
PROJECT_NAME=OSeMOSYS API (Local)
API_V1_STR=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Modo local sin Docker (archivo SQLite dentro de backend/tmp/local)
DATABASE_URL=sqlite:///./tmp/local/osemosys_local.db
DB_SCHEMA_OSEMOSYS=osemosys

# Simulación sin Redis/Celery worker
SIMULATION_MODE=sync
REDIS_URL=redis://localhost:6379/0
SIM_MAX_CONCURRENCY=1
SIM_USER_ACTIVE_LIMIT=1

SECRET_KEY=change-me-local
ACCESS_TOKEN_EXPIRE_MINUTES=60

