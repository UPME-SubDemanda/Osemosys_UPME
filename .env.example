# Puertos expuestos en el host.
API_BIND_HOST=127.0.0.1
API_PORT=8010
API_WORKERS=3
FRONTEND_BIND_HOST=0.0.0.0
FRONTEND_PORT=80
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5433
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379

# Credenciales/DB.
POSTGRES_USER=osemosys
POSTGRES_PASSWORD=osemosys
POSTGRES_DB=osemosys
DB_SCHEMA_OSEMOSYS=osemosys

# URLs internas para contenedores.
DATABASE_URL_DOCKER=postgresql+psycopg://osemosys:osemosys@db:5432/osemosys
REDIS_URL_DOCKER=redis://redis:6379/0
FRONTEND_API_UPSTREAM=api:8000
BACKEND_BRIDGE_NETWORK=osemosys_api_bridge

# Build-time vars para el frontend.
VITE_API_BASE_URL=/api/v1
VITE_APP_ENV=production
VITE_SIMULATION_MODE=api

# Ejecución de simulaciones.
SIM_WORKER_REPLICAS=1
SIM_MAX_CONCURRENCY=1
SIM_USER_ACTIVE_LIMIT=3
SIM_TOTAL_WEIGHT_LIMIT=8
SIM_WEIGHT_NATIONAL=1
SIM_WEIGHT_REGIONAL=3
SIM_SOLVER_THREADS=12

# Perfil orientado a acelerar una simulación individual con HiGHS.
OMP_NUM_THREADS=4
OPENBLAS_NUM_THREADS=4
MKL_NUM_THREADS=4

# Seguridad (cambia en ambientes reales)
SECRET_KEY=replace-me-before-deploy

# Auditoría local de espacio en disco.
DISK_AUDIT_INTERVAL_HOURS=6
DISK_ALERT_THRESHOLDS_GB=60,50,40
DISK_AUDIT_CSV_PATH=/var/log/osemosys/disk_audit.csv
DISK_ALERT_LOG_PATH=/var/log/osemosys/disk_alerts.log
