ENVIRONMENT=local
PROJECT_NAME=OSeMOSYS API
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# Orígenes permitidos por CORS.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Base de datos y Redis (en Docker se sobreescriben por docker-compose).
DATABASE_URL=postgresql+psycopg://osemosys:osemosys@db:5432/osemosys
DB_SCHEMA_OSEMOSYS=osemosys
REDIS_URL=redis://redis:6379/0

# Simulación
SIM_WORKER_REPLICAS=1
SIM_MAX_CONCURRENCY=1
SIM_USER_ACTIVE_LIMIT=3
SIM_TOTAL_WEIGHT_LIMIT=8
SIM_WEIGHT_NATIONAL=1
SIM_WEIGHT_REGIONAL=3
SIM_SOLVER_THREADS=12

# Perfil orientado a acelerar una simulación individual con HiGHS.
OMP_NUM_THREADS=4
OPENBLAS_NUM_THREADS=4
MKL_NUM_THREADS=4

# Seguridad (cambia en ambientes reales)
SECRET_KEY=replace-me-before-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Auditoría local de espacio en disco.
DISK_AUDIT_INTERVAL_HOURS=6
DISK_ALERT_THRESHOLDS_GB=60,50,40
DISK_AUDIT_CSV_PATH=/var/log/osemosys/disk_audit.csv
DISK_ALERT_LOG_PATH=/var/log/osemosys/disk_alerts.log
